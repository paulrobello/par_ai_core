# PAR AI Core example environment.
# Copy to .env and fill in only the keys for the providers/features you use.
# Every value below is a placeholder — never commit real secrets.

# ---- AI Provider API Keys ----
OPENAI_API_KEY=your-openai-api-key-here
ANTHROPIC_API_KEY=your-anthropic-api-key-here
GROQ_API_KEY=your-groq-api-key-here
XAI_API_KEY=your-xai-api-key-here
GOOGLE_API_KEY=your-google-api-key-here
MISTRAL_API_KEY=your-mistral-api-key-here
GITHUB_TOKEN=your-github-token-here
OPENROUTER_API_KEY=your-openrouter-api-key-here
DEEPSEEK_API_KEY=your-deepseek-api-key-here
AZURE_OPENAI_API_KEY=your-azure-openai-api-key-here

# ---- AWS Bedrock (optional auth) ----
# Any standard AWS credential chain works; set these if not using a named profile.
AWS_PROFILE=
AWS_ACCESS_KEY_ID=your-aws-access-key-here
AWS_SECRET_ACCESS_KEY=your-aws-secret-access-key-here
AWS_REGION=us-east-1
AWS_SESSION_TOKEN=

# ---- Local providers (optional) ----
# OLLAMA_HOST defaults to http://localhost:11434
OLLAMA_HOST=http://localhost:11434

# ---- Search ----
GOOGLE_CSE_ID=your-google-cse-id-here
GOOGLE_CSE_API_KEY=your-google-cse-api-key-here
SERPER_API_KEY=your-serper-api-key-here
TAVILY_API_KEY=your-tavily-api-key-here
JINA_API_KEY=your-jina-api-key-here
BRAVE_API_KEY=your-brave-api-key-here
REDDIT_CLIENT_ID=your-reddit-client-id-here
REDDIT_CLIENT_SECRET=your-reddit-client-secret-here
# Optional: authenticate for a higher Reddit rate limit.
REDDIT_USERNAME=
REDDIT_PASSWORD=

# ---- LangSmith tracing (optional) ----
LANGCHAIN_TRACING_V2=false
LANGCHAIN_ENDPOINT=https://api.smith.langchain.com
LANGCHAIN_API_KEY=your-langchain-api-key-here
LANGCHAIN_PROJECT=par_ai

# ---- PARAI configuration (all optional) ----
# Prefix is PARAI by default; not all providers/models support every var.
# PARAI_AI_PROVIDER=
# PARAI_MODEL=
# PARAI_AI_BASE_URL=
# PARAI_TEMPERATURE=
# PARAI_TIMEOUT=
# PARAI_STREAMING=
# PARAI_USER_AGENT_APPID=
# PARAI_NUM_CTX=           # Ollama context-window size only
# PARAI_MAX_OUTPUT_TOKENS= # output token cap (max_tokens) for non-Ollama providers
# PARAI_NUM_PREDICT=
# PARAI_REPEAT_LAST_N=
# PARAI_REPEAT_PENALTY=
# PARAI_MIROSTAT=
# PARAI_MIROSTAT_ETA=
# PARAI_MIROSTAT_TAU=
# PARAI_TFS_Z=
# PARAI_TOP_K=
# PARAI_TOP_P=
# PARAI_SEED=
# PARAI_REASONING_EFFORT=  # low / medium / high (OpenAI thinking models)
# PARAI_REASONING_BUDGET=  # Anthropic reasoning token budget
# PARAI_LOG_LEVEL=         # DEBUG / INFO / WARNING / ERROR / NOTSET
